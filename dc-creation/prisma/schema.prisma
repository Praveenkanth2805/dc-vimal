generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
}

model HomepageContent {
  id           Int      @id @default(autoincrement())
  heroTitle    String?
  heroSubtitle String?
  heroImage    String?
  aboutText    String?
  whyChooseUs  String?  // JSON array of strings
  stats        String?  // JSON array of { label: string, value: number }
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Portfolio {
  id           String   @id @default(cuid())
  title        String
  category     String
  imageUrl     String
  thumbnailUrl String?
  order        Int      @default(0)
  createdAt    DateTime @default(now())
}

model Video {
  id           String   @id @default(cuid())
  title        String
  category     String
  youtubeId    String
  thumbnailUrl String?
  order        Int      @default(0)
  createdAt    DateTime @default(now())
}

model Service {
  id          String   @id @default(cuid())
  name        String
  description String?
  icon        String?  // e.g., "FaCamera"
  category    String   // Photography, Videography, Creative
  order       Int      @default(0)
  createdAt   DateTime @default(now())
}

model Review {
  id           String   @id @default(cuid())
  customerName String
  rating       Int
  reviewText   String
  photoUrl     String?
  createdAt    DateTime @default(now())
}

model PhotoFramePrice {
  id        String   @id @default(cuid())
  size      String
  type      String
  price     Int
  createdAt DateTime @default(now())
}

model Booking {
  id        String   @id @default(cuid())
  fullName  String
  mobile    String
  eventType String
  eventDate DateTime
  venue     String?
  message   String?
  contacted Boolean  @default(false)
  createdAt DateTime @default(now())
}

model ContactInfo {
  id           Int      @id @default(autoincrement())
  address      String?
  phone        String?
  whatsapp     String?
  email        String?
  mapEmbed     String?  // Google Maps iframe code
  openingHours String?  // JSON
  socialLinks  String?  // JSON
  updatedAt    DateTime @updatedAt
}